{
  "author": "Joe Friesen @josephfriesen",
  "bin": {
    "joeserver-tools": "./bin/run.js",
    "js": "./bin/run.js",
    "js-dev": "./bin/dev.js"
  },
  "bugs": "https://github.com/josephfriesen/joeserver-tools/issues",
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "cli-progress": "^3.12.0",
    "node-taglib-sharp": "^6.0.1"
  },
  "description": "cli tools for managing joe's cool unraid server from the ubuntu vm",
  "devDependencies": {
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^5",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10",
    "@types/node": "^22.10.1",
    "@types/ssh2": "^1.11.19",
    "@types/ssh2-streams": "^0.1.12",
    "chai": "^5",
    "chalk": "^5.3.0",
    "dotenv": "^16.3.1",
    "eslint": "^9",
    "eslint-config-oclif": "^5",
    "js-yaml": "^4.1.0",
    "mocha": "^11",
    "node-ssh": "^13.1.0",
    "oclif": "^4.3.6",
    "ora": "^8.0.1",
    "puppeteer": "^23.10.2",
    "shx": "^0.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": "./lib/index.js",
  "files": [
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "homepage": "https://github.com/josephfriesen/joeserver-tools",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "",
  "name": "joeserver-tools",
  "oclif": {
    "bin": "joeserver-tools",
    "commands": "./dist/commands",
    "dirname": "joeserver-tools",
    "topicSeparator": " ",
    "topics": {
      "dap": {
        "description": "Prepare albums for the managed local DAP library, inspect library state, compare against the Echo Mini device, and sync files to or from /TUNES."
      },
      "dap state": {
        "description": "Rebuild and verify the portable manifest files that track what is present in the local and device DAP libraries."
      }
    },
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ]
  },
  "repository": "josephfriesen/joeserver-tools",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "tsc --noEmit",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "npm run build && oclif manifest && oclif readme",
    "prepare": "npm run build",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "version": "0.0.0"
}